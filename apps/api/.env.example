# ============================================================
# PsychRAG Platform — API Environment Variables
# Copy to .env and fill in your values
# ============================================================

# App
APP_NAME="PsychRAG Platform"
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# PostgreSQL
POSTGRES_USER=psych_user
POSTGRES_PASSWORD=psych_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=psych_rag

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
QUERY_CACHE_TTL=3600

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_PREFIX=psych_kb
QDRANT_VECTOR_SIZE=1024

# JWT — CHANGE IN PRODUCTION
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# Ollama / Mistral (self-hosted)
OLLAMA_BASE_URL=http://localhost:11434
MISTRAL_MODEL=mistral:7b
MISTRAL_MAX_TOKENS=512

# Embeddings
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_BATCH_SIZE=32

# RAG
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_SPARSE_WEIGHT=0.3
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# File Storage
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

# S3-compatible (Cloudflare R2 or AWS) — leave blank for local
S3_BUCKET=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto

# Firecrawl (for URL scraping)
FIRECRAWL_API_KEY=

# PubMed
PUBMED_API_KEY=
PUBMED_EMAIL=admin@yourplatform.com

# Langfuse (observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
